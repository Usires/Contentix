# Contentix Environment Variables
# Copy this file to `.env` and fill in your real values.
# `.env` is in .gitignore and will NOT be committed.

# ─── vidIQ MCP ────────────────────────────────────────────────────────────────
# Required. Get your API key from https://app.vidiq.com → Settings → API.
# Contentix uses vidIQ's MCP (Model Context Protocol) for channel and video stats.
VIDIQ_API_KEY=your_vidiq_api_key_here

# ─── OpenClaw Gateway (v0.10+ Research feature) ───────────────────────────────
# Optional. Required only if you want to use the "🔭 Nix"-Research button in the
# Kanban board (triggers Vidi AI agent to research a video idea).
# Leave blank to disable research-job features; the button will gracefully
# respond with a clear error message.
#
# GATEWAY_URL   — the base URL of your running OpenClaw gateway
#                 (e.g. http://localhost:18789 for a local install, or
#                 http://openclaw-host:18789 on a remote host)
# GATEWAY_TOKEN — bearer token for the gateway. Find in
#                 ~/.openclaw/openclaw.json under `gateway.token`.
OPENCLAW_GATEWAY_URL=
OPENCLAW_GATEWAY_TOKEN=

# ─── Server ───────────────────────────────────────────────────────────────────
# Optional. Default: 3038. Only change if 3038 is taken on your host.
PORT=3038
